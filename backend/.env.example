# =============================================================================
# WiseStay Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# Django
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL 8.0)
# -----------------------------------------------------------------------------
DB_NAME=wisestay
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis (broker + cache + channels)
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# Encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-fernet-key-here

# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# WhatsApp Business API
# -----------------------------------------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Hostaway
# -----------------------------------------------------------------------------
HOSTAWAY_API_URL=https://api.hostaway.com/v1

# Seam (IoT device management)
# -----------------------------------------------------------------------------
SEAM_API_KEY=seam_apikey_xxx

# CORS (production only, comma-separated)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://wisestay.com

# Sentry (production only)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# Security (production only)
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=True
